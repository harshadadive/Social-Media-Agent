<title>Social Spark — AI Social Media Assistant</title>
<style>
  :root {
    --purple:  #a259ff;
    --pink:    #ff6b9d;
    --blue:    #4fc3f7;
    --yellow:  #ffd166;
    --green:   #06d6a0;
    --cream:   #fdf6ff;
    --white:   #ffffff;
    --text:    #2d1b4e;
    --muted:   #8b7aa8;
    --border:  #ead9f7;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: -apple-system, "Segoe UI", system-ui, sans-serif;
    background: var(--cream);
    color: var(--text);
    font-size: 15px;
    line-height: 1.6;
  }

  /* HEADER */
  header {
    position: sticky; top: 0; z-index: 90;
    background: linear-gradient(100deg, #a259ff 0%, #c471ed 50%, #ff6b9d 100%);
    box-shadow: 0 4px 20px rgba(162,89,255,.3);
  }
  .hdr {
    max-width: 1100px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    padding: 13px 28px;
  }
  .brand { display: flex; align-items: center; gap: 11px; }
  .brand-icon {
    width: 44px; height: 44px; border-radius: 50%;
    background: #fff; display: flex; align-items: center; justify-content: center;
    font-size: 22px; box-shadow: 0 2px 10px rgba(0,0,0,.15);
  }
  .brand-text h1 { font-size: 19px; font-weight: 800; color: #fff; line-height: 1.1; }
  .brand-text p  { font-size: 11px; color: rgba(255,255,255,.85); font-weight: 600; }
  nav { display: flex; gap: 6px; }
  nav a {
    color: #fff; text-decoration: none; font-size: 13px; font-weight: 700;
    padding: 6px 15px; border-radius: 30px;
    background: rgba(255,255,255,.2); transition: background .18s;
  }
  nav a:hover { background: rgba(255,255,255,.38); }

  /* HERO */
  .hero {
    text-align: center;
    padding: 72px 24px 60px;
    background: radial-gradient(ellipse at 50% 0%, rgba(162,89,255,.12) 0%, transparent 65%);
  }
  .hero-pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: linear-gradient(135deg, #a259ff, #ff6b9d);
    color: #fff; font-size: 11px; font-weight: 800;
    letter-spacing: 1px; text-transform: uppercase;
    padding: 5px 16px; border-radius: 30px; margin-bottom: 22px;
  }
  .hero h2 { font-size: 44px; font-weight: 900; line-height: 1.12; margin-bottom: 16px; }
  .hero h2 em { font-style: normal; color: var(--purple); }
  .hero-sub { font-size: 16px; color: var(--muted); font-weight: 600; max-width: 500px; margin: 0 auto 40px; }

  .platform-row { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin-bottom: 44px; }
  .plat {
    display: flex; align-items: center; gap: 7px;
    background: #fff; border: 2px solid var(--border);
    border-radius: 50px; padding: 8px 16px;
    font-size: 13px; font-weight: 700; color: var(--text);
    box-shadow: 0 3px 10px rgba(162,89,255,.08);
  }
  .plat-ig { border-color: #f09433; }
  .plat-tw { border-color: #1da1f2; }
  .plat-fb { border-color: #1877f2; }
  .plat-yt { border-color: #ff0000; }
  .plat-tk { border-color: #555; }
  .plat-li { border-color: #0077b5; }

  .stat-row {
    display: flex; justify-content: center; gap: 12px;
    flex-wrap: wrap; max-width: 760px; margin: 0 auto 56px; padding: 0 20px;
  }
  .stat-pill {
    display: flex; align-items: center; gap: 8px;
    background: #fff; border: 2px solid var(--border);
    border-radius: 50px; padding: 8px 20px;
    box-shadow: 0 3px 10px rgba(162,89,255,.08);
  }
  .stat-pill strong { font-size: 18px; font-weight: 900; color: var(--purple); }
  .stat-pill span   { font-size: 11.5px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .4px; }

  /* SECTION */
  .section { max-width: 1100px; margin: 0 auto 64px; padding: 0 24px; }
  .sec-head { text-align: center; margin-bottom: 32px; }
  .sec-head h3 { font-size: 26px; font-weight: 900; }
  .sec-head h3 span { color: var(--purple); }
  .sec-line { width: 52px; height: 4px; background: linear-gradient(90deg,#a259ff,#ff6b9d); border-radius: 4px; margin: 8px auto 0; }

  /* TOPIC CARDS */
  .topic-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px,1fr)); gap: 20px; }
  .topic-card {
    background: #fff; border-radius: 20px; border: 2px solid var(--border);
    box-shadow: 0 6px 22px rgba(162,89,255,.09);
    padding: 24px 22px;
    transition: transform .2s, box-shadow .2s, border-color .2s;
    position: relative; overflow: hidden;
  }
  .topic-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px; }
  .tc1::before { background: linear-gradient(90deg,#a259ff,#ff6b9d); }
  .tc2::before { background: linear-gradient(90deg,#4fc3f7,#06d6a0); }
  .tc3::before { background: linear-gradient(90deg,#ffd166,#ff6b9d); }
  .tc4::before { background: linear-gradient(90deg,#06d6a0,#4fc3f7); }
  .tc5::before { background: linear-gradient(90deg,#ff6b9d,#ffd166); }
  .tc6::before { background: linear-gradient(90deg,#a259ff,#4fc3f7); }
  .topic-card:hover { transform: translateY(-5px); box-shadow: 0 16px 38px rgba(162,89,255,.18); border-color: var(--purple); }
  .topic-ico { font-size: 34px; margin-bottom: 12px; }
  .topic-card h4 { font-size: 16px; font-weight: 800; margin-bottom: 7px; }
  .topic-card p  { font-size: 13px; color: var(--muted); font-weight: 600; line-height: 1.55; margin-bottom: 14px; }
  .topic-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .ttag { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; background: #f3eaff; color: var(--purple); }

  /* HOW IT WORKS */
  .steps-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px,1fr)); gap: 20px; }
  .step-card {
    background: #fff; border: 2px solid var(--border); border-radius: 20px;
    padding: 26px 20px; text-align: center;
    box-shadow: 0 4px 14px rgba(162,89,255,.08);
  }
  .step-num {
    width: 40px; height: 40px; border-radius: 50%;
    background: linear-gradient(135deg, #a259ff, #ff6b9d); color: #fff;
    font-size: 16px; font-weight: 900;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 12px;
  }
  .step-ico { font-size: 30px; margin-bottom: 10px; }
  .step-card h4 { font-size: 15px; font-weight: 800; margin-bottom: 7px; }
  .step-card p  { font-size: 13px; color: var(--muted); font-weight: 600; line-height: 1.5; }

  /* FAQ */
  .faq-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px,1fr)); gap: 18px; }
  .faq-card {
    background: #fff; border: 2px solid var(--border); border-radius: 18px;
    padding: 20px 22px; box-shadow: 0 4px 16px rgba(162,89,255,.08);
    transition: border-color .18s;
  }
  .faq-card:hover { border-color: var(--purple); }
  .faq-q { font-size: 14px; font-weight: 800; margin-bottom: 8px; display: flex; gap: 8px; align-items: flex-start; }
  .faq-q span { color: var(--purple); font-size: 16px; flex-shrink: 0; }
  .faq-a { font-size: 13px; color: var(--muted); font-weight: 600; line-height: 1.6; }

  /* CTA */
  .cta-banner { max-width: 1100px; margin: 0 auto 64px; padding: 0 24px; }
  .cta-inner {
    background: linear-gradient(135deg, #a259ff 0%, #ff6b9d 100%);
    border-radius: 24px; padding: 48px 36px;
    text-align: center; color: #fff;
    box-shadow: 0 12px 36px rgba(162,89,255,.3);
  }
  .cta-inner h3 { font-size: 26px; font-weight: 900; margin-bottom: 10px; }
  .cta-inner p  { font-size: 15px; opacity: .9; margin-bottom: 26px; font-weight: 600; }
  .cta-btn {
    display: inline-block; padding: 13px 32px;
    background: #fff; color: var(--purple);
    border-radius: 50px; font-size: 14px; font-weight: 800;
    cursor: pointer; border: none; font-family: inherit;
    box-shadow: 0 4px 18px rgba(0,0,0,.15);
  }

  /* FOOTER */
  footer {
    background: linear-gradient(135deg, #2d1b4e, #4a2d78);
    color: rgba(255,255,255,.7); text-align: center;
    padding: 40px 24px 28px; font-size: 13px; font-weight: 600;
  }
  .f-icons { font-size: 22px; margin-bottom: 12px; letter-spacing: 4px; }
  footer strong { color: #fff; }
  .f-links { display: flex; justify-content: center; gap: 20px; margin: 14px 0; flex-wrap: wrap; }
  .f-links a { color: rgba(255,255,255,.6); text-decoration: none; font-size: 13px; font-weight: 700; }
  .f-links a:hover { color: #fff; }
  .made-with {
    display: block; margin-top: 18px; padding-top: 14px;
    border-top: 1px solid rgba(255,255,255,.14);
    font-size: 11.5px; color: rgba(255,255,255,.35);
  }
</style>
